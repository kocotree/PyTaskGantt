services:
  # ===== PyTaskGantt 应用 =====
  pytaskgantt:
    build: .
    container_name: pytaskgantt
    restart: unless-stopped
    environment:
      - NODE_ENV=production
      - PORT=3002
      - CORS_ORIGIN=${CORS_ORIGIN:?请设置为对外访问网址，例如 https://tasks.example.com}
      # DATABASE_URL 非空时优先；否则应用根据完整的五项 PG* 自动生成。
      - DATABASE_URL=${DATABASE_URL:-}
      - PGHOST=${PGHOST:-}
      - PGPORT=${PGPORT:-}
      - PGDATABASE=${PGDATABASE:-}
      - PGUSER=${PGUSER:-}
      - PGPASSWORD=${PGPASSWORD:-}
      # 留空时应用沿用 DATABASE_URL 中的 sslmode；拆分 PG* 配置可显式设置。
      # 证书路径必须是容器内绝对路径，并通过 secrets/只读 volume 挂载对应文件。
      - PGSSLMODE=${PGSSLMODE:-}
      - PGSSLROOTCERT=${PGSSLROOTCERT:-}
      - PGSSLCERT=${PGSSLCERT:-}
      - PGSSLKEY=${PGSSLKEY:-}
      - PGAPPNAME=${PGAPPNAME:-pytaskgantt}
      - PGPOOL_MAX=${PGPOOL_MAX:-10}
      - PGPOOL_IDLE_TIMEOUT_MS=${PGPOOL_IDLE_TIMEOUT_MS:-30000}
      - PGPOOL_CONNECTION_TIMEOUT_MS=${PGPOOL_CONNECTION_TIMEOUT_MS:-5000}
      - AUTH_MODE=${AUTH_MODE:?请显式设置；生产推荐 feishu，受控临时环境可使用 dev}
      - ALLOW_DEV_AUTH_IN_PRODUCTION=${ALLOW_DEV_AUTH_IN_PRODUCTION:-false}
      - SESSION_SECRET=${SESSION_SECRET:?请设置至少 32 位随机会话密钥}
      - SESSION_MAX_AGE_SECONDS=${SESSION_MAX_AGE_SECONDS:-28800}
      - SESSION_COOKIE_NAME=${SESSION_COOKIE_NAME:-pytaskgantt.sid}
      - FEISHU_APP_ID=${FEISHU_APP_ID:-}
      - FEISHU_APP_SECRET=${FEISHU_APP_SECRET:-}
      - FEISHU_REDIRECT_URI=${FEISHU_REDIRECT_URI:-}
      - APP_BASE_URL=${APP_BASE_URL:-}
      - FEISHU_AUTO_PROVISION=${FEISHU_AUTO_PROVISION:-true}
      - FEISHU_ALLOWED_TENANT_KEYS=${FEISHU_ALLOWED_TENANT_KEYS:-}
      - FEISHU_REQUEST_TIMEOUT_MS=${FEISHU_REQUEST_TIMEOUT_MS:-10000}
      - FEISHU_STATE_TTL_SECONDS=${FEISHU_STATE_TTL_SECONDS:-600}
      - FEISHU_AUTHORIZATION_URL=${FEISHU_AUTHORIZATION_URL:-https://accounts.feishu.cn/open-apis/authen/v1/authorize}
      - FEISHU_API_BASE_URL=${FEISHU_API_BASE_URL:-https://open.feishu.cn}
      - YINGDAO_ACCESS_KEY_ID=${YINGDAO_ACCESS_KEY_ID:?请设置影刀 Access Key ID}
      - YINGDAO_ACCESS_KEY_SECRET=${YINGDAO_ACCESS_KEY_SECRET:?请设置影刀 Access Key Secret}
      - YINGDAO_BASE_URL=${YINGDAO_BASE_URL:-https://api.yingdao.com}
      - YINGDAO_SYNC_INTERVAL_SECONDS=${YINGDAO_SYNC_INTERVAL_SECONDS:-60}
      - YINGDAO_SCHEDULE_CACHE_SECONDS=${YINGDAO_SCHEDULE_CACHE_SECONDS:-60}
      - YINGDAO_BIND_CACHE_MAX_AGE_SECONDS=${YINGDAO_BIND_CACHE_MAX_AGE_SECONDS:-300}
      - YINGDAO_REQUEST_TIMEOUT_MS=${YINGDAO_REQUEST_TIMEOUT_MS:-15000}
      - EXECUTION_RETENTION_DAYS=${EXECUTION_RETENTION_DAYS:-30}
      - JOB_LOG_CACHE_SECONDS=${JOB_LOG_CACHE_SECONDS:-300}
      - UI_REFRESH_SECONDS=${UI_REFRESH_SECONDS:-10}
    labels:
      # 启用 Traefik（由服务器上已有的 Traefik 实例自动发现本容器）
      - "traefik.enable=true"
      # HTTPS 路由器：把 example.com 换成你的域名
      - "traefik.http.routers.pytaskgantt.rule=Host(`example.com`)"
      # entrypoint 名称须与你的 Traefik 静态配置一致（常见为 websecure / https）
      - "traefik.http.routers.pytaskgantt.entrypoints=websecure"
      # ⚠️ certresolver 必须填你的 Traefik 实例里【实际存在】的证书解析器名字，
      #    否则路由会被静默丢弃、访问报 ERR_CONNECTION_CLOSED。
      #    查询方法：docker inspect <traefik容器> | grep certificatesresolvers
      #    取 --certificatesresolvers.<名字>.acme... 中的 <名字> 填在这里。
      - "traefik.http.routers.pytaskgantt.tls.certresolver=letsencrypt"
      # 后端服务端口（容器内 Express 监听端口，与上面 PORT 保持一致）
      - "traefik.http.services.pytaskgantt.loadbalancer.server.port=3002"
    networks:
      # 须与 Traefik 所在的 external 网络同名，否则 Traefik 发现不到本容器
      - traefik-network

networks:
  traefik-network:
    # external: true 表示复用已有网络（由 Traefik 侧创建），不在此文件中新建
    external: true
