# 复制本文件为 .env 后按需修改（.env 不入库）
# cp .env.example .env

# === 后端 server.cjs ===
# Express 服务端口；前端会同步用这个端口拼 API 地址
PORT=3002
# CORS 允许的来源；公网部署请改为白名单域名
CORS_ORIGIN=*

# === 前端 vite ===
# Vite dev server 端口
VITE_DEV_PORT=5174
# Vite dev server 监听地址（0.0.0.0 允许局域网访问）
VITE_DEV_HOST=0.0.0.0

# === 存储后端 ===
# file（默认）= 读写下方 TASKS_FILE 指定的 CSV/JSON；postgres = 写入 PostgreSQL
# 缺省即 file
STORAGE_DRIVER=file

# === 数据（STORAGE_DRIVER=file 时生效）===
# 任务数据文件路径，按扩展名自动选 JSON / CSV 读写：
#   - .json:       JSON 数组格式
#   - .csv:        Task,Start,Finish,Bot 表头的 CSV（与 streamlit 版本同源）
# 路径解析：
#   - 相对路径以 vue/ 目录为基准（默认 src/data/tasks.json）
#   - 也支持绝对路径，例如 D:/data/tasks.json 或 ../streamlit/ShadowBot_tasks.csv
TASKS_FILE=src/data/tasks.json

# === PostgreSQL（仅 STORAGE_DRIVER=postgres 时生效）===
# 建表需手动执行 storage/schema.sql，应用不会自动建表。
# 连接信息二选一：整串 DATABASE_URL，或下方分散的 PG* 变量
DATABASE_URL=postgresql://user:password@localhost:5432/pytaskgantt
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=pytaskgantt
# PGUSER=postgres
# PGPASSWORD=
