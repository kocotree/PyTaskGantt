# 复制为 .env 后填写。应用只使用 PostgreSQL，不再支持文件/CSV/JSON 运行时存储。

# === 运行模式 ===
NODE_ENV=development
PORT=3002
VITE_DEV_PORT=5174
VITE_DEV_HOST=0.0.0.0

# 开发环境可同时允许 Vite 和 Docker 入口；生产环境必须填写明确网址并启用 HTTPS。
CORS_ORIGIN=http://localhost:5174,http://localhost:3002

# === PostgreSQL（两种方式二选一）===
# DATABASE_URL 非空时优先；留空时应用会根据下方五项安全生成连接串。
DATABASE_URL=
# Docker 容器连接宿主机 PostgreSQL 时改为 host.docker.internal，不能使用 localhost。
PGHOST=localhost
PGPORT=5432
PGDATABASE=pytaskgantt
PGUSER=pytaskgantt
PGPASSWORD=change-me
# 开发本机可 disable；生产上线清单要求显式改为 verify-full。私有 CA/双向 TLS 路径必须为绝对路径。
PGSSLMODE=disable
PGSSLROOTCERT=
PGSSLCERT=
PGSSLKEY=
# 会显示在 pg_stat_activity，建议每个部署环境使用可识别且稳定的名称。
PGAPPNAME=pytaskgantt
PGPOOL_MAX=10
PGPOOL_IDLE_TIMEOUT_MS=30000
PGPOOL_CONNECTION_TIMEOUT_MS=5000

# === 登录与会话 ===
# dev 提供受控开发用户切换；feishu 使用正式飞书 OAuth 登录。
AUTH_MODE=dev
# 生产环境默认拒绝 AUTH_MODE=dev。仅受控的临时环境才可显式开启下项。
ALLOW_DEV_AUTH_IN_PRODUCTION=false
SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
SESSION_MAX_AGE_SECONDS=28800
SESSION_COOKIE_NAME=pytaskgantt.sid

# === 飞书 OAuth（AUTH_MODE=feishu 时必填；dev 模式完整填写后也可测试登录/绑定）===
# 飞书开放平台应用凭证。真实值必须通过 secret 管理注入，不得提交。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 必须与飞书应用安全设置中的重定向 URL 完全一致，并直接指向 Express 回调。
# 本地示例：http://localhost:3002/api/auth/feishu/callback
FEISHU_REDIRECT_URI=
# OAuth 完成后返回的前端 origin；本地示例 http://localhost:5174，生产环境必须为 HTTPS。
APP_BASE_URL=
# true：未绑定飞书身份首次登录时创建内部用户；false：只允许已绑定用户登录。
FEISHU_AUTO_PROVISION=true
# 可选，逗号分隔；非空时只允许这些 tenant_key。
FEISHU_ALLOWED_TENANT_KEYS=
FEISHU_REQUEST_TIMEOUT_MS=10000
FEISHU_STATE_TTL_SECONDS=600
# 一般无需修改；仅用于私有代理或测试桩。
FEISHU_AUTHORIZATION_URL=https://accounts.feishu.cn/open-apis/authen/v1/authorize
FEISHU_API_BASE_URL=https://open.feishu.cn

# === 影刀开放 API（必填，不得提交真实值）===
YINGDAO_ACCESS_KEY_ID=replace-me
YINGDAO_ACCESS_KEY_SECRET=replace-me
YINGDAO_BASE_URL=https://api.yingdao.com
YINGDAO_REQUEST_TIMEOUT_MS=15000
YINGDAO_SYNC_INTERVAL_SECONDS=60
YINGDAO_SCHEDULE_CACHE_SECONDS=60
YINGDAO_BIND_CACHE_MAX_AGE_SECONDS=300

# === 执行记录与前端刷新 ===
EXECUTION_RETENTION_DAYS=30
JOB_LOG_CACHE_SECONDS=300
UI_REFRESH_SECONDS=10
