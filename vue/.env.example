# 复制本文件为 .env 后按需修改（.env 不入库）
# cp .env.example .env
#
# Docker 部署：不需要手动创建 .env，所有配置通过 docker-compose.yml 的
# environment 段或宿主机环境变量注入。详见下方 Docker 部署说明。

# === 后端 server.cjs ===
# Express 服务端口；前端会同步用这个端口拼 API 地址
PORT=3002
# CORS 允许的来源；公网部署请改为白名单域名
CORS_ORIGIN=*

# === 前端 vite ===
# Vite dev server 端口
VITE_DEV_PORT=5174
# Vite dev server 监听地址（0.0.0.0 允许局域网访问）
VITE_DEV_HOST=0.0.0.0

# === 存储后端 ===
# file（默认）= 读写下方 TASKS_FILE 指定的 CSV/JSON；postgres = 写入 PostgreSQL
# 缺省即 file
STORAGE_DRIVER=file

# === 数据（STORAGE_DRIVER=file 时生效）===
# 任务数据文件路径，按扩展名自动选 JSON / CSV 读写：
#   - .json:       JSON 数组格式
#   - .csv:        Task,Start,Finish,Bot 表头的 CSV（与 streamlit 版本同源）
# 路径解析：
#   - 相对路径以 vue/ 目录为基准（默认 src/data/tasks.json）
#   - 也支持绝对路径，例如 D:/data/tasks.json 或 ../streamlit/ShadowBot_tasks.csv
TASKS_FILE=src/data/tasks.json

# === PostgreSQL（仅 STORAGE_DRIVER=postgres 时生效）===
# 建表需手动执行 storage/schema.sql，应用不会自动建表。
# 连接信息二选一：整串 DATABASE_URL，或下方分散的 PG* 变量
DATABASE_URL=postgresql://user:password@localhost:5432/pytaskgantt
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=pytaskgantt
# PGUSER=postgres
# PGPASSWORD=

# ===================================================================
# Docker 部署说明
# ===================================================================
#
# 快速启动（在 vue/ 目录下）：
#
#   1. 将 docker-compose.yml 中的 example.com 替换为你的真实域名
#   2. 将 Traefik 的 ACME 邮箱改为你自己的地址
#   3. 启动：
#      docker compose up -d
#
# 首次启动后访问 https://example.com 即可使用。
#
# 架构说明：
#   - Traefik 作为反向代理，自动申请/续期 Let's Encrypt 证书
#   - Express 后端同时托管 Vite 构建的前端静态文件（同源部署）
#   - 任务数据通过 Docker volume（pytaskgantt-data）持久化在 /app/data/
#
# 常用环境变量（在 docker-compose.yml 的 environment 段修改）：
#   PORT=3002               Express 监听端口
#   STORAGE_DRIVER=file     存储后端（file 或 postgres）
#   TASKS_FILE=/app/data/tasks.json   数据文件路径
#   DATABASE_URL=...        PostgreSQL 连接串（仅 STORAGE_DRIVER=postgres 时）
